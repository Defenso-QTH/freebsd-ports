+		}
 
-	if (libinput_udev_assign_seat(backend->libinput_context,
-			backend->session->seat) != 0) {
-		wlr_log(WLR_ERROR, "Failed to assign libinput seat");
-		return false;
+		char *devices_dup = strdup(devices_str);
+		if (!devices_dup) {
+			wlr_log(WLR_ERROR, "strdup failed");
+			return false;
+		}
+		char *saveptr;
+		char *path = strtok_r(devices_dup, ":", &saveptr);
+		while (path != NULL) {
+			wlr_log(WLR_DEBUG, "Adding input device: %s", path);
+			struct libinput_device *dev = libinput_path_add_device(
+				backend->libinput_context, path);
+			if (dev == NULL) {
+				wlr_log(WLR_ERROR, "Failed to add input device: %s", path);
+			}
+			path = strtok_r(NULL, ":", &saveptr);
+		}
+		free(devices_dup);
+	} else {
+		backend->libinput_context = libinput_udev_create_context(&libinput_impl,
+			backend, backend->session->udev);
+		if (!backend->libinput_context) {
+			wlr_log(WLR_ERROR, "Failed to create libinput context");
+			return false;
+		}
+
+		if (libinput_udev_assign_seat(backend->libinput_context,
+				backend->session->seat) != 0) {
+			wlr_log(WLR_ERROR, "Failed to assign libinput seat");
+			return false;
+		}
 	}
 
